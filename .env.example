# ── Banco de dados ────────────────────────────────────────────────
# Railway preenche automaticamente ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/pgmei

# ── Browser ───────────────────────────────────────────────────────
# false = Chrome visível (dev local)  |  true = headless (Railway)
HEADLESS=false
PAUSA_MS=1500
# Delay aleatório máximo (segundos) antes de cada scraper abrir o browser.
# Espalha chamadas simultâneas para evitar detecção de volume pelo PGMEI.
# 0 = desativado | 10 = recomendado para até 15 chamadas simultâneas
DELAY_MAX_S=10

# ── Login ─────────────────────────────────────────────────────────
LOGIN_USER=admin
LOGIN_PASS=sua_senha_aqui

# ── Sessão (use uma string longa e aleatória) ─────────────────────
SECRET_KEY=troque-por-uma-chave-muito-longa-e-aleatoria-aqui

# ── API Key (para integração servidor-para-servidor) ──────────────
# Deixe vazio para desativar. Envie no header: X-API-Key: <valor>
API_KEY=troque-por-uma-chave-longa-e-aleatoria-aqui
